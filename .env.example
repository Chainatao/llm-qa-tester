# URL of the upstream llm-qa /ask endpoint
LLM_QA_ENDPOINT=https://llm-qa.acion.es/ask

# Secret expected by upstream llm-qa service
LLM_QA_SECRET=change_me

# Password required to use the tester UI
TESTER_UI_PASSWORD=change_me_too

# Session signing secret and cookie settings
TESTER_SESSION_SECRET=replace_with_long_random_value
TESTER_SESSION_DAYS=30
TESTER_COOKIE_SECURE=true

# Optional timeout in seconds
REQUEST_TIMEOUT_SECONDS=180

# Retry policy for transient upstream timeout errors
UPSTREAM_MAX_RETRIES=2
UPSTREAM_RETRY_DELAY_SECONDS=1.0
